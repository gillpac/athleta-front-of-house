NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Zapier webhook for outbound email (Gmail draft via Zapier)
# If unset, confirmation emails are logged but not sent
ZAPIER_EMAIL_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/yyyyy/

# Inbound webhook secret (optional) — set in Zapier and here to validate Gravity Forms webhooks
WEBHOOK_SECRET=your-webhook-secret
